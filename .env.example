# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687  # Docker 내부: neo4j / 로컬: localhost
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# ── PostgreSQL ───────────────────────────────
POSTGRES_HOST=postgres       # Docker 내부: postgres / 로컬: localhost
POSTGRES_PORT=5432
POSTGRES_USER=riskuser
POSTGRES_PASSWORD=riskpass
POSTGRES_DB=riskdb
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── LLM (Phase 5) ────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o-mini          # 테스트: gpt-4o-mini / 운영: gpt-4o
LLM_CONFIDENCE_THRESHOLD=0.7   # 이 값 미만이면 추출 결과 거부

# ── Risk Engine Defaults ─────────────────────
DEFAULT_SHOCK_INTENSITY=1.0
DEFAULT_DECAY_LAMBDA=0.1       # λ: 시간 감쇠 계수
DEFAULT_MAX_HOP=5              # 최대 전파 홉
DEFAULT_TIME_HORIZON=30        # 기본 분석 기간 (일)
RISK_CUTOFF_THRESHOLD=0.01     # 이 값 미만 리스크는 전파 중단
